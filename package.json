{
	"name": "fishing-game",
	"version": "1.0.1",
	"description": "Terminal-style fishing game (ESM library + Electron shell)",
	"private": true,
	"type": "module",
	"main": "electron/electron-main.js",
	"scripts": {
		"bundle": "node scripts/bundle.mjs",
		"electron": "electron .",
		"dist": "npm run bundle && electron-builder --publish never"
	},
	"build": {
		"appId": "com.fishing.game",
		"productName": "Fishing Game",
		"directories": {
			"output": "dist-electron"
		},
		"files": [
			"electron/**/*",
			"package.json"
		],
		"win": {
			"icon": "electron/icons/icon.ico",
			"target": [
				"nsis",
				"portable"
			]
		},
		"linux": {
			"executableName": "fishing",
			"icon": "electron/icons/512x512.png",
			"target": [
				"AppImage",
				"deb"
			],
			"category": "Game",
			"synopsis": "Terminal-style fishing game",
			"maintainer": "lyuwenhan <81000228+lyuwenhan@users.noreply.github.com>",
			"desktop": {
				"entry": {
					"Name": "Fishing Game",
					"Comment": "Terminal-style fishing game",
					"Keywords": "game;terminal;",
					"Categories": "Game;",
					"StartupWMClass": "fishing"
				}
			}
		},
		"mac": {
			"icon": "electron/icons/icon.icns",
			"target": [
				"dmg",
				"zip"
			],
			"category": "public.app-category.games"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"installerIcon": "electron/icons/icon.ico",
			"uninstallerIcon": "electron/icons/icon.ico"
		},
		"portable": {
			"artifactName": "${productName}-Portable-${version}.${ext}"
		},
		"deb": {
			"packageName": "fishing-game"
		}
	},
	"author": {
		"name": "lyuwenhan",
		"email": "81000228+lyuwenhan@users.noreply.github.com"
	},
	"bugs": {
		"url": "https://github.com/lyuwenhan/fishing-source-code-js/issues"
	},
	"homepage": "https://github.com/lyuwenhan/fishing-source-code-js#readme",
	"devDependencies": {
		"electron": "^41.5.0",
		"electron-builder": "^26.8.1",
		"esbuild": "^0.25.0",
		"terser": "^5.46.0"
	}
}
